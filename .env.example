# FBA Brain Configuration
# Copy this file to .env and fill in your keys

# ═══════════════════════════════════════
# KEEPA API (£17/mo) — finds products on Amazon UK
# Get from: https://keepa.com → Account → API Key
KEEPA_API_KEY=

# ═══════════════════════════════════════
# CJDROPSHIPPING (FREE) — real China wholesale prices + ordering
# Sign up: https://cjdropshipping.com → Developer Centre
CJ_API_KEY=
CJ_EMAIL=
CJ_PASSWORD=

# ═══════════════════════════════════════
# AMAZON SP-API (FREE with £25/mo seller account) — auto-list + track sales
# Setup guide: https://developer-docs.amazon.com/sp-api/docs/registering-your-application
SP_CLIENT_ID=
SP_CLIENT_SECRET=
SP_REFRESH_TOKEN=
SP_SELLER_ID=

# ═══════════════════════════════════════
# GMAIL (OPTIONAL — for Tactical Arbitrage alerts)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Server
PORT=3000
