# FBA Brain Configuration
# Copy this file to .env and fill in your keys

# Keepa API (REQUIRED for real Amazon data)
# Get from: https://keepa.com → Account → API Key
# Cost: €19/month
KEEPA_API_KEY=

# Gmail Integration (OPTIONAL - for Tactical Arbitrage alerts)
# Follow Google OAuth2 setup: https://developers.google.com/gmail/api/quickstart
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Server
PORT=3000
